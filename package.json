{
  "name": "rishicodes-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:public": "turbo dev --filter=@rishicodes/public",
    "dev:admin": "turbo dev --filter=@rishicodes/admin",
    "dev:api": "turbo dev --filter=@rishicodes/api",
    "build": "turbo build",
    "build:public": "turbo build --filter=@rishicodes/public",
    "build:admin": "turbo build --filter=@rishicodes/admin",
    "build:api": "turbo build --filter=@rishicodes/api",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @rishicodes/db generate",
    "db:migrate": "pnpm --filter @rishicodes/db migrate:dev",
    "db:deploy": "pnpm --filter @rishicodes/db migrate:deploy",
    "postinstall": "pnpm db:generate",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@11.9.0",
  "dependencies": {
    "tailwindcss-animate": "^1.0.7"
  }
}
