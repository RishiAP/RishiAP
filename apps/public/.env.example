# ── API ──
NEXT_PUBLIC_API_URL=http://localhost:3002

# ── Site URLs ──
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── ISR Revalidation ──
REVALIDATE_SECRET=your_random_32_char_secret_here
